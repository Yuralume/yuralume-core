# Yuralume self-host compose settings.
#
# Provider keys are configured after boot from Admin -> Provider Keys.
# Do not put LLM / embedding / image / video / TTS keys in this file.

# Image tag pulled by docker-compose.container.yml. Set to a published
# version (e.g. v0.1.0) for reproducible deploys; leave as `latest`
# during evaluation. Only consulted when the compose file resolves
# images from ghcr.io; local `--build` rebuilds always.
# YURALUME_IMAGE_TAG=latest
# Optional local-build metadata surfaced by /api/v1/system/version.
# CI-published app images inject these automatically.
# YURALUME_BUILD_SHA=
# YURALUME_BUILD_TIME=

APP_ENV=production
# Public domain
APP_BASE_URL=http://127.0.0.1:8012
KOKORO_LOG_LEVEL=INFO

# Optional browser Web Push. When all three are set, users can enable OS-level
# notifications in Player Settings. Leave unset to keep SSE/in-app notifications only.
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
# How long (seconds) the push service retains an undeliverable message for
# store-and-forward. Default 86400 (24h); 0 = live-only, dropped when the
# device is offline/dozing.
# WEB_PUSH_TTL_SECONDS=86400

# Interface timezone for the local single user (IANA, e.g. Asia/Taipei) — civil
# dates/times, schedules, "today" boundaries. DB and server instants stay UTC.
# In single-user mode this seeds the default operator at first boot (same as
# USER_PRIMARY_LANGUAGE).
USER_TIMEZONE=UTC

# Default interface + content language for the local single user. In single-user
# mode (AUTH_ENABLED=false) this seeds the default operator at first boot so the
# UI and character replies come up in this language. Valid: zh-TW, en-US, ja-JP.
USER_PRIMARY_LANGUAGE=zh-TW

# Optional login IP geolocation seed for mutable user location.
# Private/loopback IPs are ignored; users can edit the location later.
GEOIP_ENABLED=true
# GEOIP_PROVIDER=ip-api
# GEOIP_ENDPOINT=http://ip-api.com/json/
# GEOIP_CACHE_TTL_SECONDS=86400
# GEOIP_TIMEOUT_SECONDS=3

POSTGRES_USER=kokoro
POSTGRES_PASSWORD=kokoro_dev
POSTGRES_DB=kokoro_link
DATABASE_URL=postgresql+asyncpg://kokoro:kokoro_dev@postgres:5432/kokoro_link

# Single-machine self-host can keep auth off. Set both when enabling login.
AUTH_ENABLED=false
# JWT_SECRET=change-me-to-a-long-random-string-32+chars
# JWT_TTL_SECONDS=604800

# Hosted Yuralume Cloud mode. When enabled, this core instance disables local
# setup/user/provider management surfaces and routes identity/resources through
# Yuralume Cloud phases. JWT_SECRET is still required because the core signs its
# own short-lived session token after federation.
# YURALUME_CLOUD_ENABLED=false
# YURALUME_CLOUD_USER_SERVICE_URL=https://user-api.yuralume.example
# YURALUME_CLOUD_GATEWAY_URL=https://gateway.yuralume.example
# YURALUME_CLOUD_DEPLOYMENT_TOKEN=change-me
# YURALUME_CLOUD_DEPLOYMENT_ID=hosted-primary
# YURALUME_CLOUD_DEPLOYMENT_AUDIENCE=yuralume-gateway
# Versioned Core -> User service credential: key|caller|audience|scopes|secret.
# Required when YURALUME_CLOUD_ENABLED=true; supports key rotation on the User side.
# YURALUME_CLOUD_USER_INTERNAL_CREDENTIAL=core-kid|core|yuralume-user|demo-session:release,introspection:session,runtime:read|change-me
# YURALUME_CLOUD_INTROSPECT_TIMEOUT=5
# YURALUME_CLOUD_SESSION_TTL_SECONDS=3600
# Shared secret for the hosted-play SSO entry flow (plan H0): sent as
# X-Internal-Token when Core POSTs a portal-issued one-time code to the
# User service /internal/v1/hosted-play/exchange endpoint. Must match the
# User service's YURALUME_HOSTED_PLAY_INTERNAL_TOKEN. Blank disables the
# header (demo-only deployments).
# YURALUME_CLOUD_HOSTED_PLAY_INTERNAL_TOKEN=change-me
# Public demo strict no-fallback needs every live-demo LLM feature pinned.
# Example:
# YURALUME_CLOUD_LLM_PRESETS=chat=gb10-chat,character_draft=gb10-draft,post_turn=gb10-post-turn,schedule_plan=gb10-schedule,proactive_intention=gb10-proactive,busy_reply_decide=gb10-busy,scene_access=gb10-scene,register_profile=gb10-register,novelty_gate=gb10-novelty,prompt_material_digest=gb10-digest,feed_compose=gb10-feed,activity_aftermath=gb10-aftermath,idle_drift=gb10-idle
# YURALUME_CLOUD_IMAGE_PRESET=yuralume-anime
# YURALUME_CLOUD_VIDEO_PRESET=yuralume-anime
# YURALUME_CLOUD_TTS_VOICE=
# When true, Core cloud mode resolves feature_key -> preset from the control-plane
# routing profile instead of YURALUME_CLOUD_LLM_PRESETS (which becomes a deprecated
# one-release fallback). See docs/CLOUD_CONTROL_PLANE_CONFIG_PLAN.md Phase 3.
# YURALUME_CLOUD_RUNTIME_CONFIG_ENABLED=false
# Shared secret sent as X-Internal-Token on Core's runtime-config pulls
# (core-profile + per-tier runtime-profile). Lets the hosted User service
# authenticate the internal channel instead of leaving it open. Must match the
# User service's internal-token config. Blank disables the header.
# YURALUME_CLOUD_RUNTIME_CONFIG_INTERNAL_TOKEN=change-me
# Hosted deployments set this true to reject free "standard" tenants at Core
# login (only paid tiers and demo may sign in). Leave false/unset for self-host
# and existing cloud, where any active account may log in.
# YURALUME_CLOUD_REQUIRE_PAID_TIER=false

# Hosted demo OAuth PUBLIC client ids. Served to the SPA at RUNTIME via
# GET /api/v1/auth/demo/oauth/config (plan Phase 5.1), so changing a client id no
# longer needs a fresh SPA build. Set these on the Core *container runtime* env.
# These are public client ids, not secrets (provider secrets live in Cloud User).
# YURALUME_DEMO_DISCORD_CLIENT_ID=
# YURALUME_DEMO_GOOGLE_CLIENT_ID=

# Hosted demo OAuth frontend build constants. The client-id Vite vars below are now
# an OPTIONAL fallback only — the SPA fetches the client id at runtime (see above),
# so a deployment no longer has to bake them in. The conversion URLs remain Vite
# build-time values; setting them only at container runtime cannot change an
# already-built SPA.
# VITE_YURALUME_DEMO_DISCORD_CLIENT_ID=
# VITE_YURALUME_DEMO_GOOGLE_CLIENT_ID=
# VITE_YURALUME_DEMO_TIER0_URL=https://yuralume.com/#demo-showcase
# VITE_YURALUME_DEMO_WAITLIST_URL=https://yuralume.com/#alpha
# VITE_YURALUME_DEMO_DISCORD_URL=https://discord.gg/tF8zw7S6
# VITE_YURALUME_DEMO_SELF_HOST_URL=https://yuralume.com/#tiers

# Required before saving provider keys in Admin -> Provider Keys.
CONFIG_ENCRYPTION_KEY=change-me-to-a-long-random-string-32+chars

DEPLOYMENT_MODE=container
STORAGE_PROVIDER=http
STORAGE_URL=http://storage-local:9000
STORAGE_KEY=change-me
# New DB media refs are app-relative (/v1/public/...). Set this only if an
# external storage/CDN service returns URLs that the app must reverse-map.
# STORAGE_PUBLIC_URL=https://media.example.com
# STORAGE_TIMEOUT_SECONDS=30

# WhatsApp sidecar gateway. The compose service name is the default; players do
# not enter this in the UI. When WHATSAPP_SIDECAR_API_TOKEN is set, the backend
# automatically stores the same token in new WhatsApp account credentials.
WHATSAPP_SIDECAR_URL=http://whatsapp-sidecar:32190
WHATSAPP_SIDECAR_PORT=32190
# WHATSAPP_SIDECAR_API_TOKEN=
# WHATSAPP_SIDECAR_LOG_LEVEL=info

# Optional first-run admin bootstrap. When both are set and the
# default user still has no credentials, app startup attaches them
# automatically (same effect as walking through /auth/setup once).
# Becomes a no-op after the first successful run. Safe to leave in
# place; safer to delete the password after first boot. Honoured
# whether AUTH_ENABLED is true or false — flipping the auth switch
# later picks up the seeded admin.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# Optional tools.
# TAVILY_API_KEY=tvly-xxxxxxxxxxxx
# WEB_FETCH_TIMEOUT=15

# Self-host NSFW mode TTL. The mode is manually enabled per user and routes
# LLM/image calls to the configured community targets until idle expiry.
# NSFW_MODE_TTL_SECONDS=1800

# Optional prompt pack overlay for self-host Docker. Put tuned files on the
# host under ./prompts/tuned with the same relative paths as
# src/kokoro_link/data/prompts/. docker-compose.container.yml mounts that
# directory into the app container at /app/prompts/tuned.
# YURALUME_PROMPT_PACK_DIR=/app/prompts/tuned

# Optional generation usage price catalog. The bundled OpenAI sample covers
# Standard LLM token pricing that maps cleanly to Core usage rows.
# KOKORO_USAGE_PRICE_CATALOG_PATH=/app/usage-prices.openai.json
