  "12": {
    "inputs": {"shift": 8.0, "model": ["2", 0]},
    "class_type": "ModelSamplingSD3",
    "_meta": {"title": "ModelSampling low"}
  },
  "8": {
    "inputs": {
      "add_noise": "enable", "noise_seed": 42, "steps": 20, "cfg": 5.0,
      "sampler_name": "euler", "scheduler": "simple",
      "start_at_step": 0, "end_at_step": 10, "return_with_leftover_noise": "enable",
      "model": ["11", 0], "positive": ["4", 0], "negative": ["5", 0], "latent_image": ["7", 0]
    },
    "class_type": "KSamplerAdvanced",
    "_meta": {"title": "Wan sample high-noise"}
  },
  "9": {
    "inputs": {
      "add_noise": "disable", "noise_seed": 42, "steps": 20, "cfg": 5.0,
