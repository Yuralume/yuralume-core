      "model": ["12", 0], "positive": ["4", 0], "negative": ["5", 0], "latent_image": ["8", 0]
    },
    "class_type": "KSamplerAdvanced",
    "_meta": {"title": "Wan sample low-noise"}
  },
  "10": {
    "inputs": {"samples": ["9", 0], "vae": ["6", 0]},
    "class_type": "VAEDecode",
